# MUSIC BOX - DISCOGS CONFIG
# Cuenta objetivo de Google Drive local: segunmercader.g@gmail.com
MUSIC_MASTER=C:\Users\segun\Google Drive\Music_Master
MUSICBOX_ROOT=C:\Users\segun\Google Drive\MUSIC_BOX

# Multi-ruta opcional: varias raices a indexar, separadas por ';'.
# Si se deja vacia, se usa MUSIC_MASTER (comportamiento actual).
# Ejemplo: MUSIC_ROOTS=C:\Users\segun\Google Drive\Music_Master;D:\Musica;E:\USB_DJ
MUSIC_ROOTS=

# Discogs: crea un User Token en Discogs > Settings > Developers
# No pegues el token en ChatGPT. Solo aqui, en tu PC.
DISCOGS_TOKEN=
DISCOGS_USER_AGENT=MusicBoxDiscogs/0.1 +local
DISCOGS_API_BASE=https://api.discogs.com
DISCOGS_CACHE_TTL_SECONDS=604800

# API local
MUSICBOX_API_HOST=127.0.0.1
MUSICBOX_API_PORT=8765
